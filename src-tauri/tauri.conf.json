{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "editor",
  "version": "0.1.0",
  "identifier": "com.stargrazer-games.kgeditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "editor",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' engine-asset: asset: https://tauri.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
